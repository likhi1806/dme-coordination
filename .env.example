# Pick ONE (or both). Provider auto-selected; override with LLM_PROVIDER=anthropic|openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-4o-mini

# Using an OpenAI-COMPATIBLE gateway (e.g. FastRouter, OpenRouter, an internal
# proxy)? Set the key above as OPENAI_API_KEY and add the base URL + model here.
# No code change needed — the OpenAI SDK reads these from the environment.
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://go.fastrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini

# Voice: simulated (default) | offline (no LLM/key needed — scripted fallback)
#        | vapi (real outbound call to YOUR phone)
# VOICE_PROVIDER=vapi
# VAPI_API_KEY=
# VAPI_PHONE_NUMBER_ID=
# VAPI_TARGET_NUMBER=+1XXXXXXXXXX
